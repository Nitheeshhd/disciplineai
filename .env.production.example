APP_NAME=DisciplineAI SaaS
APP_ENV=production
APP_VERSION=2.0.0
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
TIMEZONE=UTC
LOG_LEVEL=INFO
ENABLE_DOCS=false

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=replace_with_strong_secret
JWT_REFRESH_SECRET_KEY=replace_with_strong_refresh_secret
BOT_TOKEN_ENCRYPTION_KEY=replace_with_fernet_key_44_chars
PASSWORD_MIN_LENGTH=12
ALLOWED_ORIGINS=https://your-frontend.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60

WRITE_DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/disciplineai
READ_DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/disciplineai
SQL_ECHO=false
DB_POOL_SIZE=30
DB_MAX_OVERFLOW=60

REDIS_URL=redis://redis:6379/0
DASHBOARD_CACHE_TTL_SECONDS=60

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
INACTIVE_DAYS_THRESHOLD=7

TELEGRAM_BOT_TOKEN=replace_with_bot_token
WEBHOOK_BASE_URL=https://your-api-domain.com
WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_string
