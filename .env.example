APP_NAME=DisciplineAI SaaS
APP_ENV=development
APP_VERSION=2.0.0
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
TIMEZONE=UTC
LOG_LEVEL=INFO
ENABLE_DOCS=true

# Security
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=change_me_access_secret
JWT_REFRESH_SECRET_KEY=change_me_refresh_secret
BOT_TOKEN_ENCRYPTION_KEY=6Aa3moc7dwoJ3slSMkdFKCYf9XsU79xy1go9-ygfXjw=
PASSWORD_MIN_LENGTH=8
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Databases (write/read split for CQRS)
WRITE_DATABASE_URL=sqlite+aiosqlite:///./disciplineai.db
READ_DATABASE_URL=sqlite+aiosqlite:///./disciplineai.db
SQL_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Redis + cache + rate limit
REDIS_URL=redis://localhost:6379/0
DASHBOARD_CACHE_TTL_SECONDS=60

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
INACTIVE_DAYS_THRESHOLD=7

# Telegram
TELEGRAM_BOT_TOKEN=CHANGE_ME
WEBHOOK_BASE_URL=https://your-domain.com
WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_string

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
SESSION_SECRET_KEY=super-secret-session-key
